# ── Database ─────────────────────────────────────────────────────────────────
# Used by the API container to connect to Postgres.
# When using the docker-compose.yml db service, the host is "db".
DATABASE_URL=postgresql://postgres:CHANGE_ME@db:5432/lakeside

POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_USER=postgres
POSTGRES_DB=lakeside

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── Email (optional) ─────────────────────────────────────────────────────────
# Leave blank to disable email notifications. The site works fine without them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=
