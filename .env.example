# ── Server ───────────────────────────────────────────────────────────────────
# Port the API server listens on. Required — the server refuses to start without it.
PORT=8080

# ── Database ─────────────────────────────────────────────────────────────────
# Used by the API container to connect to Postgres.
# When using the docker-compose.yml db service, the host is "db".
DATABASE_URL=postgresql://postgres:CHANGE_ME@db:5432/lakeside

POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_USER=postgres
POSTGRES_DB=lakeside

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Set to "false" to allow non-HTTPS session cookies (e.g. local HTTP testing). Only
# takes effect when NODE_ENV=production; cookies are already non-secure in dev.
COOKIE_SECURE=true

# Optional query-string token for GET /api/admin/auth/debug (an admin session is
# also required). Leave blank to keep the route effectively disabled.
DEBUG_TOKEN=

# ── Email (optional) ─────────────────────────────────────────────────────────
# Leave blank to disable email notifications. The site works fine without them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Also used to seed/update the admin login on every server boot (paired with
# ADMIN_PASSWORD below).
ADMIN_EMAIL=

# Paired with ADMIN_EMAIL to seed/update the admin login on every server boot.
ADMIN_PASSWORD=

# Base URL used to build the "view in admin panel" link inside lead-notification
# emails. Defaults to https://lakesidetaxi.co.uk if unset.
ADMIN_URL=

# ── Google Reviews (optional) ─────────────────────────────────────────────────
# Leave blank to use the built-in fallback reviews instead of live Google data.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ── Google Maps (optional) ────────────────────────────────────────────────────
# Baked into the frontend JS bundle at build time (passed as a Docker build arg
# in docker-compose.yml). Leave blank to disable the interactive coverage map.
VITE_GOOGLE_MAPS_API_KEY=

# ── Logging ──────────────────────────────────────────────────────────────────
# pino log level: trace | debug | info | warn | error | fatal. Defaults to "info".
LOG_LEVEL=info
